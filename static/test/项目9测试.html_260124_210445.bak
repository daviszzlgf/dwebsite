<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>项目9测试 - 网页多媒体应用</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        :root {
            --primary: #2c3e50;
            --secondary: #3498db;
            --accent: #e74c3c;
            --light: #ecf0f1;
            --dark: #2c3e50;
            --success: #2ecc71;
            --warning: #f39c12;
            --info: #9b59b6;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }
        
        body {
            background-color: #f9f9f9;
            color: #333;
            line-height: 1.6;
        }
        
        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        /* 头部样式 */
        header {
            background: linear-gradient(135deg, #8e44ad 0%, #3498db 100%);
            color: white;
            padding: 1rem 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: var(--shadow);
        }
        
        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            display: flex;
            align-items: center;
            font-size: 1.5rem;
            font-weight: bold;
        }
        
        .logo i {
            margin-right: 10px;
            color: var(--accent);
        }
        
        nav ul {
            display: flex;
            list-style: none;
        }
        
        nav li {
            margin-left: 1.5rem;
        }
        
        nav a {
            color: white;
            text-decoration: none;
            font-weight: 500;
            padding: 0.5rem 0.8rem;
            border-radius: 4px;
            transition: var(--transition);
        }
        
        nav a:hover, nav a.active {
            background-color: rgba(255, 255, 255, 0.2);
        }
        
        /* 页面标题 */
        .page-header {
            background: linear-gradient(to right, #8e44ad, #3498db);
            color: white;
            padding: 3rem 0;
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .page-header h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .breadcrumb {
            display: flex;
            justify-content: center;
            list-style: none;
        }
        
        .breadcrumb li {
            margin: 0 0.5rem;
        }
        
        .breadcrumb li:not(:last-child)::after {
            content: ">";
            margin-left: 1rem;
        }
        
        .breadcrumb a {
            color: var(--light);
            text-decoration: none;
        }
        
        .breadcrumb a:hover {
            text-decoration: underline;
        }
        
        /* 测试说明 */
        .test-info {
            background: white;
            border-radius: 10px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow);
            border-left: 4px solid #8e44ad;
        }
        
        .test-info h2 {
            color: #8e44ad;
            margin-bottom: 1rem;
        }
        
        .test-info ul {
            list-style: none;
            margin: 1rem 0;
        }
        
        .test-info li {
            padding: 0.5rem 0;
            display: flex;
            align-items: center;
        }
        
        .test-info i {
            color: #8e44ad;
            margin-right: 10px;
        }
        
        /* 内容区域 */
        .content-section {
            background: white;
            border-radius: 10px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow);
        }
        
        .content-section h2 {
            color: #8e44ad;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #8e44ad;
            display: flex;
            align-items: center;
        }
        
        .content-section h2 i {
            margin-right: 10px;
            color: #8e44ad;
        }
        
        /* 题目区域 */
        .question-section {
            margin-bottom: 2rem;
        }
        
        .question-type {
            color: #8e44ad;
            font-size: 1.3rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }
        
        .question-type i {
            margin-right: 10px;
            color: #8e44ad;
        }
        
        .question {
            margin-bottom: 1.5rem;
            padding: 1.2rem;
            border-radius: 8px;
            background: var(--light);
            border-left: 4px solid #8e44ad;
        }
        
        .question-title {
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--dark);
        }
        
        .question-title span {
            color: #8e44ad;
            margin-right: 5px;
        }
        
        .options {
            list-style: none;
        }
        
        .option {
            margin-bottom: 0.8rem;
            padding: 0.8rem;
            background: white;
            border-radius: 4px;
            cursor: pointer;
            transition: var(--transition);
            border: 1px solid #ddd;
        }
        
        .option:hover {
            background: #f0f7ff;
            border-color: #8e44ad;
        }
        
        .option.selected {
            background: #f3e6f8;
            border-color: #8e44ad;
        }
        
        .option input {
            margin-right: 10px;
        }
        
        /* 判断题样式 */
        .true-false-options {
            display: flex;
            gap: 1rem;
        }
        
        .tf-option {
            flex: 1;
            text-align: center;
            padding: 1rem;
            border-radius: 6px;
            cursor: pointer;
            transition: var(--transition);
            border: 2px solid #ddd;
            font-weight: 500;
        }
        
        .tf-option.selected-true {
            background: #e8f5e9;
            border-color: var(--success);
            color: var(--success);
        }
        
        .tf-option.selected-false {
            background: #ffebee;
            border-color: var(--accent);
            color: var(--accent);
        }
        
        /* 填空题样式 */
        .fill-blank {
            margin-top: 1rem;
        }
        
        .fill-input {
            padding: 0.5rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            margin: 0 0.5rem;
            width: 200px;
        }
        
        /* 问答题样式 */
        .essay-question {
            margin-top: 1rem;
        }
        
        .essay-answer {
            width: 100%;
            min-height: 100px;
            padding: 1rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-family: inherit;
            resize: vertical;
        }
        
        /* 按钮区域 */
        .button-group {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin: 2rem 0;
        }
        
        .btn {
            padding: 0.8rem 2rem;
            border-radius: 5px;
            border: none;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .btn i {
            margin-right: 8px;
        }
        
        .btn-submit {
            background: var(--success);
            color: white;
        }
        
        .btn-submit:hover {
            background: #27ae60;
        }
        
        .btn-reset {
            background: var(--warning);
            color: white;
        }
        
        .btn-reset:hover {
            background: #e67e22;
        }
        
        /* 结果区域 */
        .result-section {
            background: white;
            border-radius: 10px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow);
            display: none;
        }
        
        .result-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .result-score {
            font-size: 3rem;
            font-weight: bold;
            color: #8e44ad;
            margin: 1rem 0;
        }
        
        .result-message {
            font-size: 1.2rem;
            color: #666;
        }
        
        .result-details {
            margin-top: 2rem;
        }
        
        .result-item {
            padding: 1rem;
            border-bottom: 1px solid #eee;
            display: flex;
            align-items: center;
        }
        
        .result-item:last-child {
            border-bottom: none;
        }
        
        .result-icon {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 0.9rem;
        }
        
        .result-correct .result-icon {
            background: var(--success);
            color: white;
        }
        
        .result-incorrect .result-icon {
            background: var(--accent);
            color: white;
        }
        
        /* 页脚 */
        footer {
            background: var(--dark);
            color: white;
            padding: 3rem 0 1rem;
            margin-top: 3rem;
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .footer-section h3 {
            margin-bottom: 1.5rem;
            position: relative;
            padding-bottom: 0.5rem;
        }
        
        .footer-section h3::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 50px;
            height: 2px;
            background: var(--accent);
        }
        
        .footer-contact span {
            display: block;
            margin-bottom: 0.5rem;
        }
        
        .footer-links ul {
            list-style: none;
        }
        
        .footer-links li {
            margin-bottom: 0.8rem;
        }
        
        .footer-links a {
            color: #ddd;
            text-decoration: none;
            transition: var(--transition);
        }
        
        .footer-links a:hover {
            color: var(--accent);
            padding-left: 5px;
        }
        
        .footer-social {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
            justify-content: center;
        }
        
        .footer-social a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            color: white;
            transition: var(--transition);
        }
        
        .footer-social a:hover {
            background: var(--secondary);
            transform: translateY(-3px);
        }
        
        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                text-align: center;
            }
            
            nav ul {
                margin-top: 1rem;
                flex-wrap: wrap;
                justify-content: center;
            }
            
            nav li {
                margin: 0.5rem;
            }
            
            .true-false-options {
                flex-direction: column;
            }
            
            .button-group {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- 头部 -->
    <header>
        <div class="container header-content">
            <div class="logo">
                <i class="fas fa-video"></i>
                <span>网页设计与制作</span>
            </div>
            <nav>
                <ul>
                    <li><a href="../课程概况.html">课程概况</a></li>
                    <li><a href="../入门攻略.html">入门攻略</a></li>
                    <li><a href="../课程学习.html">课程学习</a></li>
                    <li><a href="../教学资源.html">教学资源</a></li>
                    <li><a href="../综合测试.html">综合测试</a></li>
                    <li><a href="../课程评价.html">课程评价</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- 页面标题 -->
    <section class="page-header">
        <div class="container">
            <h1>项目9：网页多媒体应用测试</h1>
            <ul class="breadcrumb">
                <li><a href="../index.html">首页</a></li>
                <li><a href="../综合测试.html">综合测试</a></li>
                <li>项目9测试</li>
            </ul>
        </div>
    </section>

    <!-- 主要内容 -->
    <div class="container">
        <!-- 测试说明 -->
        <section class="test-info">
            <h2><i class="fas fa-info-circle"></i> 测试说明</h2>
            <p>本项目测试涵盖《项目9：网页中的多媒体应用》中的所有知识点，包括音视频格式、HTML5多媒体标签、CSS美化播放器以及多媒体兼容性等。</p>
            <ul>
                <li><i class="fas fa-check-circle"></i> 选择题：6题，每题约9分</li>
                <li><i class="fas fa-check-circle"></i> 判断题：5题，每题约9分</li>
                <li><i class="fas fa-check-circle"></i> 总分：100分</li>
                <li><i class="fas fa-check-circle"></i> 建议完成时间：20分钟</li>
            </ul>
        </section>

        <!-- 选择题部分 -->
        <section class="content-section">
            <h2><i class="fas fa-question-circle"></i> 选择题</h2>
            <p>请选择正确的答案，每题只有一个正确答案。</p>
            
            <div class="question-section">
                <h3 class="question-type"><i class="fas fa-list-ol"></i> 一、选择题（共6题，每题约9分）</h3>
                
                <!-- 选择题1 -->
                <div class="question" data-correct="B" data-type="choice">
                    <div class="question-title"><span>1.</span> 以下哪种视频格式是网页中的 "通用格式"，支持所有现代浏览器、手机和平板设备？</div>
                    <ul class="options">
                        <li class="option">
                            <input type="radio" name="q1" id="q1_a" value="A">
                            <label for="q1_a">A. WebM</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q1" id="q1_b" value="B">
                            <label for="q1_b">B. MP4</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q1" id="q1_c" value="C">
                            <label for="q1_c">C. OGV</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q1" id="q1_d" value="D">
                            <label for="q1_d">D. FLV</label>
                        </li>
                    </ul>
                </div>
                
                <!-- 选择题2 -->
                <div class="question" data-correct="B" data-type="choice">
                    <div class="question-title"><span>2.</span> 在 HTML5 的&lt;audio&gt;标签中，用于显示浏览器默认播放控件（播放/暂停、音量调节等）的属性是？</div>
                    <ul class="options">
                        <li class="option">
                            <input type="radio" name="q2" id="q2_a" value="A">
                            <label for="q2_a">A. show-controls</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q2" id="q2_b" value="B">
                            <label for="q2_b">B. controls</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q2" id="q2_c" value="C">
                            <label for="q2_c">C. display-controls</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q2" id="q2_d" value="D">
                            <label for="q2_d">D. play-controls</label>
                        </li>
                    </ul>
                </div>
                
                <!-- 选择题3 -->
                <div class="question" data-correct="C" data-type="choice">
                    <div class="question-title"><span>3.</span> 若需让视频在播放前显示一张封面图，应使用&lt;video&gt;标签的哪个属性？</div>
                    <ul class="options">
                        <li class="option">
                            <input type="radio" name="q3" id="q3_a" value="A">
                            <label for="q3_a">A. cover</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q3" id="q3_b" value="B">
                            <label for="q3_b">B. img</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q3" id="q3_c" value="C">
                            <label for="q3_c">C. poster</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q3" id="q3_d" value="D">
                            <label for="q3_d">D. thumbnail</label>
                        </li>
                    </ul>
                </div>
                
                <!-- 选择题4 -->
                <div class="question" data-correct="B" data-type="choice">
                    <div class="question-title"><span>4.</span> 以下关于 OGG 音频格式的描述，正确的是？</div>
                    <ul class="options">
                        <li class="option">
                            <input type="radio" name="q4" id="q4_a" value="A">
                            <label for="q4_a">A. 兼容性100%，支持所有主流浏览器</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q4" id="q4_b" value="B">
                            <label for="q4_b">B. 开源有损格式，压缩效率优于 MP3，IE/Safari 不支持</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q4" id="q4_c" value="C">
                            <label for="q4_c">C. 无损格式，音质极佳但体积庞大</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q4" id="q4_d" value="D">
                            <label for="q4_d">D. 是网页背景音的首选格式</label>
                        </li>
                    </ul>
                </div>
                
                <!-- 选择题5 -->
                <div class="question" data-correct="B" data-type="choice">
                    <div class="question-title"><span>5.</span> 某开发者设置了&lt;video autoplay&gt;，但视频未自动播放，最可能的原因是？</div>
                    <ul class="options">
                        <li class="option">
                            <input type="radio" name="q5" id="q5_a" value="A">
                            <label for="q5_a">A. 未添加 controls 属性</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q5" id="q5_b" value="B">
                            <label for="q5_b">B. 未配合 muted 属性（部分浏览器策略限制）</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q5" id="q5_c" value="C">
                            <label for="q5_c">C. 视频文件路径错误</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q5" id="q5_d" value="D">
                            <label for="q5_d">D. 浏览器不支持 HTML5 视频标签</label>
                        </li>
                    </ul>
                </div>
                
                <!-- 选择题6 -->
                <div class="question" data-correct="A" data-type="choice">
                    <div class="question-title"><span>6.</span> CSS 中，用于修改视频播放器 "全屏/退出全屏按钮" 样式的伪元素是？</div>
                    <ul class="options">
                        <li class="option">
                            <input type="radio" name="q6" id="q6_a" value="A">
                            <label for="q6_a">A. ::-webkit-media-controls-fullscreen-button</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q6" id="q6_b" value="B">
                            <label for="q6_b">B. ::-webkit-media-controls-fullscreen</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q6" id="q6_c" value="C">
                            <label for="q6_c">C. ::-webkit-fullscreen-button</label>
                        </li>
                        <li class="option">
                            <input type="radio" name="q6" id="q6_d" value="D">
                            <label for="q6_d">D. ::-webkit-media-fullscreen-button</label>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- 判断题部分 -->
        <section class="content-section">
            <h2><i class="fas fa-check-circle"></i> 判断题</h2>
            <p>判断下列说法的对错，正确的选"对"，错误的选"错"。</p>
            
            <div class="question-section">
                <h3 class="question-type"><i class="fas fa-balance-scale"></i> 二、判断题（共5题，每题约9分）</h3>
                
                <!-- 判断题1 -->
                <div class="question" data-correct="true" data-type="true-false">
                    <div class="question-title"><span>1.</span> MP3 格式是网页音频的首选，因其兼容性 100%，且音质与体积平衡。</div>
                    <div class="true-false-options">
                        <div class="tf-option" data-value="true">对</div>
                        <div class="tf-option" data-value="false">错</div>
                    </div>
                </div>
                
                <!-- 判断题2 -->
                <div class="question" data-correct="true" data-type="true-false">
                    <div class="question-title"><span>2.</span> &lt;audio&gt;标签的loop属性可实现音频循环播放，无需额外配置即可生效。</div>
                    <div class="true-false-options">
                        <div class="tf-option" data-value="true">对</div>
                        <div class="tf-option" data-value="false">错</div>
                    </div>
                </div>
                
                <!-- 判断题3 -->
                <div class="question" data-correct="true" data-type="true-false">
                    <div class="question-title"><span>3.</span> Chrome、Edge 等主流浏览器均支持以 "-webkit-" 开头的音视频控件伪元素，如::-webkit-media-controls。</div>
                    <div class="true-false-options">
                        <div class="tf-option" data-value="true">对</div>
                        <div class="tf-option" data-value="false">错</div>
                    </div>
                </div>
                
                <!-- 判断题4 -->
                <div class="question" data-correct="false" data-type="true-false">
                    <div class="question-title"><span>4.</span> WAV 音频格式体积庞大，适合作为网页背景音长时间播放。</div>
                    <div class="true-false-options">
                        <div class="tf-option" data-value="true">对</div>
                        <div class="tf-option" data-value="false">错</div>
                    </div>
                </div>
                
                <!-- 判断题5 -->
                <div class="question" data-correct="true" data-type="true-false">
                    <div class="question-title"><span>5.</span> 在&lt;video&gt;标签中，poster属性的值应为视频封面图的文件路径，而非仅文件名。</div>
                    <div class="true-false-options">
                        <div class="tf-option" data-value="true">对</div>
                        <div class="tf-option" data-value="false">错</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 按钮区域 -->
        <div class="button-group">
            <button class="btn btn-submit" id="submitTest">
                <i class="fas fa-paper-plane"></i> 提交测试
            </button>
            <button class="btn btn-reset" id="resetTest">
                <i class="fas fa-redo"></i> 重置答案
            </button>
        </div>

        <!-- 结果区域 -->
        <section class="result-section" id="resultSection">
            <div class="result-header">
                <h2><i class="fas fa-award"></i> 测试结果</h2>
                <div class="result-score" id="finalScore">0</div>
                <p class="result-message" id="resultMessage">您的测试结果将显示在这里</p>
            </div>
            
            <div class="result-details" id="resultDetails">
                <!-- 结果详情将动态生成 -->
            </div>
        </section>
    </div>

    <!-- 页脚 -->
    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>关于我们</h3>
                    <p>我们致力于提供高质量的网页设计与制作教育，帮助学生掌握前沿技术，实现职业发展。</p>
                </div>
                
                <div class="footer-section">
                    <h3>联系方式</h3>
                    <div class="footer-contact">
                        <span><i class="fas fa-map-marker-alt"></i> 郑州市郑东新区金龙路188号</span>
                        <span><i class="fas fa-phone"></i> 010-12345678</span>
                        <span><i class="fas fa-envelope"></i> contact@webcourse.com</span>
                    </div>
                </div>
                
                <div class="footer-section">
                    <h3>关注我们</h3>
                    <p>在社交媒体上关注我们，获取最新课程更新和学习资源。</p>
                    <div class="footer-social">
                        <a href="#"><i class="fab fa-weixin"></i></a>
                        <a href="#"><i class="fab fa-weibo"></i></a>
                        <a href="#"><i class="fab fa-qq"></i></a>
                        <a href="#"><i class="fab fa-github"></i></a>
                    </div>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2025 网页设计与制作课程 | 版权所有</p>
            </div>
        </div>
    </footer>

    <script>
        // 选择题交互逻辑
        document.querySelectorAll('.option').forEach(option => {
            option.addEventListener('click', function() {
                const question = this.closest('.question');
                const radio = this.querySelector('input[type="radio"]');
                
                // 选中当前选项
                radio.checked = true;
                
                // 移除同一问题中其他选项的选中样式
                question.querySelectorAll('.option').forEach(opt => {
                    opt.classList.remove('selected');
                });
                
                // 添加当前选项的选中样式
                this.classList.add('selected');
            });
        });
        
        // 判断题交互逻辑
        document.querySelectorAll('.tf-option').forEach(option => {
            option.addEventListener('click', function() {
                const question = this.closest('.question');
                const value = this.getAttribute('data-value');
                
                // 移除同一问题中其他选项的选中样式
                question.querySelectorAll('.tf-option').forEach(opt => {
                    opt.classList.remove('selected-true', 'selected-false');
                });
                
                // 添加当前选项的选中样式
                if (value === 'true') {
                    this.classList.add('selected-true');
                } else {
                    this.classList.add('selected-false');
                }
                
                // 存储用户的选择
                this.setAttribute('data-selected', 'true');
            });
        });
        
        // 提交测试按钮逻辑
        document.getElementById('submitTest').addEventListener('click', function() {
            let score = 0;
            const totalQuestions = 11; // 6个选择题 + 5个判断题
            const pointsPerQuestion = 100 / totalQuestions; // 每题分数
            let correctAnswers = 0;
            let resultDetailsHTML = '';
            
            // 检查所有选择题
            document.querySelectorAll('.question[data-type="choice"]').forEach((question, index) => {
                const questionNumber = index + 1;
                const correctAnswer = question.getAttribute('data-correct');
                const selectedOption = question.querySelector('input[type="radio"]:checked');
                let isCorrect = false;
                
                if (selectedOption && selectedOption.value === correctAnswer) {
                    score += pointsPerQuestion;
                    correctAnswers++;
                    isCorrect = true;
                }
                
                // 构建结果详情
                resultDetailsHTML += `
                    <div class="result-item ${isCorrect ? 'result-correct' : 'result-incorrect'}">
                        <div class="result-icon">
                            ${isCorrect ? '✓' : '✗'}
                        </div>
                        <div>
                            <strong>第${questionNumber}题（选择题）</strong><br>
                            <span>您的答案：${selectedOption ? selectedOption.value : '未作答'}</span><br>
                            <span>正确答案：${correctAnswer}</span>
                        </div>
                    </div>
                `;
            });
            
            // 检查所有判断题
            document.querySelectorAll('.question[data-type="true-false"]').forEach((question, index) => {
                const questionNumber = index + 1 + 6; // 判断题从第7题开始
                const correctAnswer = question.getAttribute('data-correct');
                const selectedOption = question.querySelector('.tf-option[data-selected="true"]');
                let userAnswer = '';
                let isCorrect = false;
                
                if (selectedOption) {
                    userAnswer = selectedOption.getAttribute('data-value');
                    if (userAnswer === correctAnswer) {
                        score += pointsPerQuestion;
                        correctAnswers++;
                        isCorrect = true;
                    }
                }
                
                // 构建结果详情
                resultDetailsHTML += `
                    <div class="result-item ${isCorrect ? 'result-correct' : 'result-incorrect'}">
                        <div class="result-icon">
                            ${isCorrect ? '✓' : '✗'}
                        </div>
                        <div>
                            <strong>第${questionNumber}题（判断题）</strong><br>
                            <span>您的答案：${userAnswer ? (userAnswer === 'true' ? '对' : '错') : '未作答'}</span><br>
                            <span>正确答案：${correctAnswer === 'true' ? '对' : '错'}</span>
                        </div>
                    </div>
                `;
            });
            
            // 四舍五入分数
            score = Math.round(score * 10) / 10;
            
            // 显示结果
            document.getElementById('finalScore').textContent = score;
            document.getElementById('resultDetails').innerHTML = resultDetailsHTML;
            
            // 根据分数显示不同的消息
            let message = '';
            if (score >= 90) {
                message = '优秀！您对网页多媒体应用的知识掌握得非常扎实！';
            } else if (score >= 70) {
                message = '良好！您已经掌握了多媒体应用的大部分核心知识，但还有一些细节需要加强。';
            } else if (score >= 60) {
                message = '及格！您对多媒体应用有基本了解，建议复习项目9的相关知识点。';
            } else {
                message = '需要加强！建议重新学习项目9的内容，掌握网页多媒体应用的核心技术。';
            }
            
            document.getElementById('resultMessage').textContent = `您答对了${correctAnswers}题，共${totalQuestions}题。${message}`;
            
            // 显示结果区域
            document.getElementById('resultSection').style.display = 'block';
            
            // 滚动到结果区域
            document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth' });
        });
        
        // 重置测试按钮逻辑
        document.getElementById('resetTest').addEventListener('click', function() {
            // 重置所有选择题
            document.querySelectorAll('input[type="radio"]').forEach(radio => {
                radio.checked = false;
            });
            
            // 移除所有选项的选中样式
            document.querySelectorAll('.option').forEach(option => {
                option.classList.remove('selected');
            });
            
            // 重置所有判断题
            document.querySelectorAll('.tf-option').forEach(option => {
                option.classList.remove('selected-true', 'selected-false');
                option.removeAttribute('data-selected');
            });
            
            // 隐藏结果区域
            document.getElementById('resultSection').style.display = 'none';
            
            // 滚动到顶部
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
</body>
</html>